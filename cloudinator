function createTerraform() {

  if [[ ! "$(which terraform)" ]]; then
    echo "ERROR: Please install Terraform ! boudiou !"
    exit 1
  fi
  if [[ ! "$(which jq)" ]]; then
    echo "ERROR: Please install jq ! boudiou !"
    exit 1
  fi
  if [[ -z "$cfZoneId" ]]; then
    echo "ERROR: --zone is required for terraform"
    exit 1
  fi
  if [[ -z "$cfAccountId" ]]; then
    echo "ERROR: --account is required for terraform"
    exit 1
  fi

  echo "===== GENERATING TERRAFORM ====="
  export CLOUDFLARE_API_TOKEN=$cfApiToken
  mkdir -p "$outDirectory/terraform"
  cd "$outDirectory/terraform"
  # Clean previous run
  rm -f *.tf import.tf

  cat > main.tf <<EOF
terraform {
  required_providers {
    cloudflare = {
      source  = "cloudflare/cloudflare"
      version = "~> 4.0"
    }
  }
}
provider "cloudflare" {}
EOF

  terraform init
  # ── Generate HCL + state ──────────────────────────────────────────────────────
  echo "===== FETCHING RESOURCES ====="
  getRecords
  getWafCustomRules
  getRewriteRules
  getRedirectRules
  getRateLimitingRules
  getConfigurationRules
  getOriginRules
  getCacheRules
  getResponseHeaderRules
  getCompressionRules
  getPageRules
  getDdosL4Overrides
  getDdosL7Overrides
  getWafManagedRulesetOverrides
  #getTunnels
  #getLbPools
  #getLbMonitors
  #getLoadBalancers
  #getHealthchecks

  echo "===== PLAN ====="
  terraform plan -out=plan.bin
  # terraform apply plan.bin

}

case "$command" in
  *D*)
    dumpAccount
    dumpZones
    [[ "$merge" == "true" ]] && mergeConfig
    ;;
  *T*)
    createTerraform
    ;;
  *)
    echo "No command specified"
    usage
    ;;
esac

exit


