echo "Fetching healthchecks..."
result=$(fetchApi "zones/$cfZoneId/healthchecks")
if echo "$result" | jq -e '.result[]' > /dev/null 2>&1; then
  echo "$result" | jq -r '.result[] | .id' \
    | while read id; do
        getTfImport "cloudflare_healthcheck" "healthcheck_$id" "$cfZoneId/$id"
      done
  getTfConfig healthchecks-$cfZoneId.tf
fi