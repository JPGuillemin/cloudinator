echo "Fetching LB pools..."
result=$(fetchApi "accounts/$cfAccountId/load_balancers/pools")
if echo "$result" | jq -e '.result[]' > /dev/null 2>&1; then
  echo "$result" | jq -r '.result[] | .id' \
    | while read id; do
        getTfImport "cloudflare_load_balancer_pool" "pool_$id" "$cfAccountId/$id"
      done
  getTfConfig load-balancers-pools-$cfAccountId.tf
fi