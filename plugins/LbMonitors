echo "Fetching LB monitors..."
result=$(fetchApi "accounts/$cfAccountId/load_balancers/monitors")
if echo "$result" | jq -e '.result[]' > /dev/null 2>&1; then
  echo "$result" | jq -r '.result[] | .id' \
    | while read id; do
        getTfImport "cloudflare_load_balancer_monitor" "monitor_$id" "$cfAccountId/$id"
      done
  getTfConfig load-balancers-monitors-$cfAccountId.tf
fi